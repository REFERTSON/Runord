<Window x:Class="Runord.Client.App.Windows.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Runord.Client.App.Windows"
        mc:Ignorable="d"
        Title="LauncherWindow" Height="500" Width="700">

    <Grid Background="#232426">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2.5*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="1">
            <Border.Background>
                <ImageBrush ImageSource="pack://application:,,,/Resources/Images/LauncherImage.jpg"
                            Stretch="UniformToFill"/>
            </Border.Background>
        </Border>

        <ContentControl Grid.Column="0" x:Name="Form"/>

        <StackPanel x:Name="Title" Orientation="Horizontal" Grid.Column="1"
            Margin="30" VerticalAlignment="Top" HorizontalAlignment="Left">
            <!-- внутренний отступ внутри подложки -->
            <Image Source="pack://application:,,,/Resources/Images/Icons/Logo.png"
                   Width="35" Height="35"/>
            <TextBlock Text="Runord"
                       FontFamily="pack://application:,,,/Resources/Fonts/#Rubik Regular"
                       Foreground="White"
                       FontSize="24"
                       Margin="15,5,0,0"/>
        </StackPanel>
    </Grid>
</Window>
