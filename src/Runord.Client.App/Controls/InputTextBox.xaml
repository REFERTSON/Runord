<UserControl x:Class="Runord.Client.App.Controls.InputTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Runord.Client.App.Controls"
             xmlns:conv="clr-namespace:Runord.Client.App.Converters"
             MinWidth="200" MinHeight="40"
             Loaded="InputBox_Loaded"
             Unloaded="InputBox_Unloaded">

    <UserControl.Resources>
        <conv:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Style="{StaticResource OuterBorderStyle}">
        <Grid>
            <!-- Основной TextBox -->
            <TextBox x:Name="PART_InputTextBox"
                     Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Padding="5,2,30,2"
                     VerticalContentAlignment="Top"
                     HorizontalContentAlignment="Left"
                     TextWrapping="{Binding TextWrapping, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     Background="Transparent"
                     Foreground="#FFFFFF"
                     CaretBrush="#FFFFFF"
                     BorderThickness="0"
                     Margin="5,8"/>

            <!-- Placeholder -->
            <TextBlock x:Name="PlaceholderText"
                       Text="{Binding Placeholder, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="Gray"
                       IsHitTestVisible="False"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="16,10,0,0"
                       TextWrapping="{Binding TextWrapping, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Visibility="{Binding Text,
                                            ElementName=PART_InputTextBox,
                                            Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"/>
        </Grid>
    </Border>
</UserControl>