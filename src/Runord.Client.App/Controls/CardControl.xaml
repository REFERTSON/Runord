<UserControl x:Class="Runord.Client.App.Controls.CardControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Runord.Client.App.Controls"
             mc:Ignorable="d"
             d:Height="110"
             d:Width="290">

    <Border Style="{StaticResource OuterBorderStyle}">

        <Grid>
            <!-- Заголовок -->
            <TextBlock Text="{Binding Title, ElementName=Root, TargetNullValue='Заголовок по умолчанию', FallbackValue='Заголовок по умолчанию'}"
                       FontFamily="{Binding FontFamily, ElementName=Root}"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Foreground="#D0D0D0"
                       Margin="30,25,51,56"
                       Height="25"/>

            <!-- Значение -->
            <TextBlock Text="{Binding Value, ElementName=Root, TargetNullValue='0', FallbackValue='0'}"
                       FontFamily="{Binding FontFamily, ElementName=Root}"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="30,50,76,0"
                       Width="180"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Left"/>
        </Grid>
    </Border>
</UserControl>