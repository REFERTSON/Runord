<UserControl x:Class="Runord.Client.App.Controls.SearchBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Runord.Client.App.Converters"
             MinWidth="200"
             Width="300"
             Height="40"
             Loaded="SearchBox_Loaded">

    <UserControl.Resources>
        <conv:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Style="{StaticResource OuterBorderStyle}">
        <Grid>
            <TextBox x:Name="PART_SearchTextBox"
                     Text="{Binding SearchText, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Padding="5,2,30,2"
                     VerticalContentAlignment="Center"
                     Background="Transparent"
                     Foreground="#FFFFFF"
                     CaretBrush="#FFFFFF"
                     BorderThickness="0" Margin="5,0,2,0"/>

            <!-- Placeholder -->
            <TextBlock x:Name="PlaceholderText"
                       Text="Поиск..."
                       Foreground="Gray"
                       IsHitTestVisible="False"
                       Margin="15,0,34,0"
                       VerticalAlignment="Center"
                       Visibility="{Binding Text, ElementName=PART_SearchTextBox, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"/>

            <!-- Иконка лупы -->
            <Image Source="pack://application:,,,/Resources/Images/Icons/Search.png"
                   Width="12"
                   Height="12"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Margin="0,0,12,0"
                   IsHitTestVisible="False"
                   SnapsToDevicePixels="True"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

        </Grid>
    </Border>
</UserControl>
