<UserControl x:Class="Runord.Client.App.Views.TaskBuilderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:enums="clr-namespace:Runord.Client.Shared.Enums;assembly=Runord.Client.Shared"
             xmlns:controls="clr-namespace:Runord.Client.App.Controls"
             mc:Ignorable="d"
             MinWidth="900" MinHeight="700">

    <Grid Margin="200,80" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Создание задачи"
                   Grid.Row="0"
                   FontSize="26"
                   Foreground="White"
                   FontFamily="pack://application:,,,/Resources/Fonts/#Roboto Flex"
                   FontWeight="SemiBold"
                   Margin="0,0,0,30"
                   HorizontalAlignment="Left"/>

        <!-- Область с прокруткой -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">

            <!-- Основная форма с использованием Grid -->
            <Grid Margin="0,0,10,0" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Название -->
                <Grid Grid.Row="0" Margin="0,0,0,25" HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Название"
                               Foreground="White"
                               FontSize="14"
                               Margin="0,0,0,8"/>

                    <controls:InputTextBox Grid.Row="1"
                                           Text="{Binding Title, Mode=TwoWay}"
                                           Placeholder="Название задачи"
                                           Width="Auto"/>
                </Grid>

                <!-- Описание -->
                <Grid Grid.Row="1" Margin="0,0,0,25" HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Описание (не обязательно)"
                               Foreground="White"
                               FontSize="14"
                               Margin="0,0,0,8"/>

                    <controls:InputTextBox Grid.Row="1"
                                           Text="{Binding Description, Mode=TwoWay}"
                                           Placeholder="Описание задачи"
                                           Width="Auto"
                                           Height="100"
                                           TextWrapping="Wrap"/>
                </Grid>

                <!-- Разделительная линия 1 -->
                <Border Grid.Row="2" 
                        Height="1" 
                        Background="#444" 
                        Margin="0,0,0,25"/>

                <!-- Тип задачи и приоритет -->
                <Grid Grid.Row="3" Margin="0,0,0,20" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <!-- Тип задачи -->
                        <ColumnDefinition Width="*"/>
                        <!-- Приоритет задачи -->
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <!-- Добавлен отступ справа -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Тип задачи"
                                   Foreground="White"
                                   FontSize="14"
                                   Margin="0,0,0,8"/>

                        <controls:CustomComboBox Grid.Row="1"
                                                 HorizontalAlignment="Stretch"
                                                 ItemsSource="{Binding TaskTypes}"
                                                 Placeholder="--------"
                                                 Width="Auto"/>
                    </Grid>

                    <Grid Grid.Column="1" Margin="10,0,0,0">
                        <!-- Добавлен отступ слева -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Приоритет задачи"
                                   Foreground="White"
                                   FontSize="14"
                                   Margin="0,0,0,8"/>

                        <controls:CustomComboBox Grid.Row="1"
                                                 HorizontalAlignment="Stretch"
                                                 Placeholder="--------"
                                                 ItemsSource="{Binding Priorities}"
                                                 Width="Auto"/>  
                    </Grid>
                </Grid>

                <!-- Исполнитель -->
                <Grid Grid.Row="4" Margin="0,0,0,20" HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Исполнитель"
                               Foreground="White"
                               FontSize="14"
                               Margin="0,0,0,8"/>
                    
                    <controls:CustomComboBox Grid.Row="1"
                                             HorizontalAlignment="Stretch"
                                             Placeholder="--------"
                                             ItemsSource="{Binding Executors}"
                                             Width="Auto"/>
                </Grid>

                <!-- Параметры -->
                <Grid Grid.Row="5" Margin="0,0,0,25" HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Параметры"
                               Foreground="White"
                               FontSize="14"
                               Margin="0,0,0,15"/>

                    <!-- Динамический список параметров -->
                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding Parameters}"
                                  HorizontalAlignment="Stretch">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               FontSize="12"/>

                                    <controls:InputTextBox Grid.Column="1"
                                                           Text="{Binding Value, Mode=TwoWay}"
                                                           Placeholder="Прикрепить файл"
                                                           HorizontalAlignment="Stretch"
                                                           Margin="10,0,10,0"/>

                                    <Button Grid.Column="2"
                                            Content="X"
                                            Command="{Binding DataContext.RemoveParameterCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Foreground="White"
                                            Background="#AA3333"
                                            Width="25"
                                            Height="25"
                                            FontSize="10"
                                            Padding="0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <!-- Разделительная линия 2 -->
                <Border Grid.Row="6" 
                        Height="1" 
                        Background="#444" 
                        Margin="0,0,0,25"/>

                <!-- Кнопки действий -->
                <Grid Grid.Row="7" Margin="0,0,0,20" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <controls:IconActionButton Grid.Column="0"
                                               Text="Отменить"
                                               Width="125"/>

                    <controls:IconActionButton Grid.Column="2"
                                               Text="Добавить"
                                               Width="120"/>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>