<UserControl x:Class="Runord.Client.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Runord.Client.App.Views"
             xmlns:vm="clr-namespace:Runord.Client.App.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.DataContext>
        <vm:SettingsViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Фон кнопки -->
                            <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"/>

                            <!-- Контент -->
                            <ContentPresenter HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                        </Grid>

                        <!-- Триггеры для эффектов -->
                        <ControlTemplate.Triggers>
                            <!-- Наведение -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#333333"/>
                            </Trigger>

                            <!-- Нажатие -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#444444"/>
                            </Trigger>

                            <!-- Дефолтная активная категория (можно задавать через Tag или DataBinding) -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="#555555"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#232426">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель категорий -->
        <StackPanel Grid.Column="0" Background="#1F1F1F">
            <Button Content="Общие" Tag="GeneralSettings" Style="{StaticResource CategoryButtonStyle}" Margin="0,10" Click="CategoryButton_Click"/>
            <Button Content="Уведомления" Tag="NotificationSettings" Style="{StaticResource CategoryButtonStyle}" Margin="0,10" Click="CategoryButton_Click"/>
            <Button Content="Интерфейс" Tag="InterfaceSettings" Style="{StaticResource CategoryButtonStyle}" Margin="0,10" Click="CategoryButton_Click"/>
            <Button Content="Сеть" Tag="NetworkSettings" Style="{StaticResource CategoryButtonStyle}" Margin="0,10" Click="CategoryButton_Click"/>
            <Button Content="Ноды" Tag="NodeSettings" Style="{StaticResource CategoryButtonStyle}" Margin="0,10" Click="CategoryButton_Click"/>
            <Button Content="Безопасность" Tag="SecuritySettings" Style="{StaticResource CategoryButtonStyle}" Margin="0,10" Click="CategoryButton_Click"/>
        </StackPanel>

        <!-- Правая панель с настройками -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SettingsPanel" Margin="20">
                <ItemsControl x:Name="SettingsItemsControl" ItemsSource="{Binding GeneralSettings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,5">
                                <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}" Foreground="#AAAAAA" FontSize="12"/>

                                <!-- Типы элементов управления -->
                                <ContentControl>
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Style.Triggers>
                                                <!-- CheckBox для Boolean -->
                                                <DataTrigger Binding="{Binding Type}" Value="Boolean">
                                                    <Setter Property="Content">
                                                        <Setter.Value>
                                                            <CheckBox IsChecked="{Binding Value}" Foreground="White"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>

                                                <!-- ComboBox для Option -->
                                                <DataTrigger Binding="{Binding Type}" Value="Option">
                                                    <Setter Property="Content">
                                                        <Setter.Value>
                                                            <ComboBox ItemsSource="{Binding Options}" SelectedItem="{Binding Value}" Width="150"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>

                                                <!-- TextBox для String/Number -->
                                                <DataTrigger Binding="{Binding Type}" Value="String">
                                                    <Setter Property="Content">
                                                        <Setter.Value>
                                                            <TextBox Text="{Binding Value}" Width="150"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Number">
                                                    <Setter Property="Content">
                                                        <Setter.Value>
                                                            <TextBox Text="{Binding Value}" Width="80"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
