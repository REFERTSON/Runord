<UserControl x:Class="Runord.Client.App.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Runord.Client.App.Views"
             xmlns:controls="clr-namespace:Runord.Client.App.Controls"
             mc:Ignorable="d"
             MinWidth="900" MinHeight="700">
    
    <Grid Background="#1F1F1F">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- FilterMenu / остальное -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Управление пользователями"
               FontSize="26"
               Foreground="White"
               FontFamily="pack://application:,,,/Resources/Fonts/#Roboto Flex"
               FontWeight="SemiBold"
               Margin="44,48,44,20"
               Grid.Row="0"/>

        <!-- Панель инструментов -->
        <controls:Toolbar Width="Auto"
                      HorizontalAlignment="Stretch"
                      Height="60"
                      Grid.Row="1"
                      Margin="44,0,44,0"/>

        <!-- Фильтры -->
        <!--<controls:FilterMenu Height="370"
                         Margin="44,0,44,10"
                         Grid.Row="3"/>-->

        <!-- Таблица -->
        <Border Style="{StaticResource OuterBorderStyle}" ClipToBounds="True" Margin="44,10,44,20" Grid.Row="2">
            <DataGrid ItemsSource="{Binding Tasks}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  ColumnWidth="*"
                  MinColumnWidth="100"
                  RowHeight="40"
                  FontFamily="Rubik"
                  FontWeight="Normal"
                  FontSize="14"
                  HorizontalScrollBarVisibility="Auto"
                  GridLinesVisibility="Horizontal"
                  Background="Transparent"
                  Foreground="White"
                  HeadersVisibility="Column"
                  BorderThickness="0"
                  SnapsToDevicePixels="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Hidden"
                  ClipToBounds="True"
                  ColumnHeaderStyle="{StaticResource TableColumnHeaderStyle}"
                  RowStyle="{StaticResource TableRowStyle}">

                <DataGrid.Columns>
                    <!-- UUID -->
                    <DataGridTextColumn Header="UUID" Binding="{Binding Id}" Width="200" IsReadOnly="True"/>

                    <!-- Название -->
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="150"/>

                    <!-- Тип задачи -->
                    <DataGridTextColumn Header="Тип задачи" Binding="{Binding Type}" Width="120"/>

                    <!-- Статус -->
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>

                    <!-- Приоритет -->
                    <DataGridTextColumn Header="Приоритет" Binding="{Binding Priority}" Width="100"/>

                    <!-- Дата создания -->
                    <DataGridTextColumn Header="Дата создания" Binding="{Binding CreationDate, StringFormat='dd.MM.yyyy HH:mm'}" Width="120"/>

                    <!-- Действия -->
                    <DataGridTemplateColumn Header=" " Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Удалить" 
                                    Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Margin="2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
