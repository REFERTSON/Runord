<UserControl x:Class="Runord.Client.App.Views.NodeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Runord.Client.App.Controls"
             mc:Ignorable="d"
             MinWidth="900" MinHeight="700">

    <Grid Background="#1F1F1F">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- FilterMenu / остальное -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Узлы"
               FontSize="26"
               Foreground="White"
               FontFamily="pack://application:,,,/Resources/Fonts/#Roboto Flex"
               FontWeight="SemiBold"
               Margin="44,48,44,20"
               Grid.Row="0"/>



        <!-- Панель инструментов -->
        <controls:Toolbar Width="Auto"
                      HorizontalAlignment="Stretch"
                      Height="60"
                      Grid.Row="1"
                      Margin="44,0,44,0"/>

        <ItemsControl Grid.Row="2"
              ItemsSource="{Binding Nodes}"
              Margin="40,20">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <!-- UniformGrid с 4 колонками -->
                    <UniformGrid Columns="4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <controls:NodeControl/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>


    </Grid>
</UserControl>
