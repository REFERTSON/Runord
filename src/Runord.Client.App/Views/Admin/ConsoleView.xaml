<UserControl x:Class="Runord.Client.App.Views.ConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Runord.Client.App.Views"
             xmlns:controls="clr-namespace:Runord.Client.App.Controls"
             mc:Ignorable="d"
             MinWidth="900" MinHeight="700">

    <UserControl.Resources>
        <Style x:Key="ConsoleTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>

        <Style x:Key="CommandPromptStyle" TargetType="TextBlock" BasedOn="{StaticResource ConsoleTextStyle}">
            <Setter Property="Foreground" Value="#4ADE80"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
        </Style>

        <!-- Конвертер BooleanToVisibility -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="#1F1F1F">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Консоль"
               FontSize="26"
               Foreground="White"
               FontFamily="pack://application:,,,/Resources/Fonts/#Roboto Flex"
               FontWeight="SemiBold"
               Margin="44,48,44,20"
               Grid.Row="0"/>

        <!-- Экран консоли -->
        <Border Style="{StaticResource OuterBorderStyle}" Grid.Row="1" Margin="44,0,44,20">
            <Grid Margin="25,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Приветственное сообщение -->
                <TextBlock Grid.Row="0" Style="{StaticResource ConsoleTextStyle}" 
                           FontFamily="pack://application:,,,/Resources/Fonts/#Rubik Regular"
                           Text="Welcome to Runord CLI. Type 'help' for a list of commands" 
                           Margin="0,0,0,20"/>

                <!-- Область вывода команд -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <ListBox x:Name="ConsoleOutputItems" 
                             ItemsSource="{Binding ConsoleLines}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Зеленая стрелка для команд -->
                                    <TextBlock Grid.Column="0" 
                                               Text="&gt; " 
                                               Style="{StaticResource CommandPromptStyle}"
                                               Margin="0,0,5,0"
                                               Visibility="{Binding IsCommand, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Текст команды или результата -->
                                    <TextBlock Grid.Column="1"
                                               Style="{StaticResource ConsoleTextStyle}" 
                                               Text="{Binding Text}" 
                                               TextWrapping="NoWrap"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Поле ввода команды -->
        <Border Style="{StaticResource OuterBorderStyle}" Grid.Row="2" Margin="44,0,44,44">
            <Grid Margin="10,5" Height="30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Приглашение командной строки -->
                <TextBlock Grid.Column="0" 
                          Text="&gt; " 
                          Style="{StaticResource CommandPromptStyle}" 
                          VerticalAlignment="Center" 
                          Margin="5,0,2,0"/>

                <!-- Поле ввода команды -->
                <TextBox Grid.Column="1" 
                        x:Name="CommandInput"
                        Style="{StaticResource InputTextBoxStyle}"
                        Text="{Binding CurrentCommand, UpdateSourceTrigger=PropertyChanged}"
                        VerticalContentAlignment="Center"
                        KeyDown="CommandInput_KeyDown"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>