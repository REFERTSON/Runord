<UserControl x:Class="Runord.Client.App.Views.UserSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Runord.Client.App.Views"
             mc:Ignorable="d" 
             d:DesignHeight="510" d:DesignWidth="400"
             Background="#232426">
    
    <Grid Margin="20 5">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontFamily="pack://application:,,,/Resources/Fonts/#Rubik Regular"
                   Foreground="White"
                   FontSize="16"
                   Text="Выберите профиль"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"/>

        <ScrollViewer x:Name="UsersProfileList"
                      Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Hidden">
            <StackPanel>
                <!-- Надпись при пустом списке -->
                <TextBlock Text="Пользователи не найдены"
                           Foreground="Gray"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,20">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Users.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Список пользователей -->
                <ItemsControl ItemsSource="{Binding Users}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Style="{StaticResource UserCardStyle}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Height="40" Width="320"
                Style="{StaticResource FormButtonStyle}"
                Content="+ Добавить пользователя"
                FontSize="13"/>
    </Grid>
</UserControl>
