<UserControl x:Class="Runord.Client.App.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Runord.Client.App.Views"
             mc:Ignorable="d"
             d:DesignHeight="510" d:DesignWidth="400"
             Background="#232426">

    <Grid Margin="25,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Вход в систему"
                   Foreground="White"
                   FontSize="24"
                   FontWeight="Bold"
                   Grid.Row="0"/>

        <!-- Подзаголовок -->
        <TextBlock Text="Введите ваши данные для продолжения"
                   Foreground="#888"
                   FontSize="13"
                   Margin="0,5,0,0"
                   Grid.Row="1"/>

        <!-- Адрес хаба -->
        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock Text="Адрес хаба" Foreground="#AAA" FontSize="13" Margin="3,0,0,4"/>
        </StackPanel>

        <!-- Email -->
        <StackPanel Grid.Row="4" Margin="0,10,0,0">
            <TextBlock Text="Электронная почта" Foreground="#AAA" FontSize="13" Margin="3,0,0,4"/>
            <Border Background="#222" CornerRadius="12" Padding="10" BorderThickness="1" BorderBrush="#444">
                <DockPanel>
                    <Image Source="pack://application:,,,/Resources/Images/Icons/Email.png" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left"/>
                    <TextBox x:Name="EmailBox"
                             Style="{StaticResource PlaceholderTextBoxStyle}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             Tag="your@email.com" />
                </DockPanel>
            </Border>
        </StackPanel>

        <!-- Пароль -->
        <StackPanel Grid.Row="5" Margin="0,10,0,0">
            <TextBlock Text="Пароль" Foreground="#AAA" FontSize="13" Margin="3,0,0,4"/>
            <Border Background="#222" CornerRadius="12" Padding="10" BorderThickness="1" BorderBrush="#444">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0">
                        <Image Source="pack://application:,,,/Resources/Images/Icons/Email.png" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left"/>
                        <!-- 
                          Если у тебя есть кастомный PasswordBox с поддержкой плейсхолдера — применяй стиль.
                          Если нет — можно заменить на TextBox с IsPassword="True" из сторонних библиотек.
                          Или сделать плейсхолдер вручную через наложение TextBlock, меняющий видимость при фокусе.
                        -->
                        <PasswordBox x:Name="PasswordBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     Tag="Введите пароль" />
                        <!-- Tag нужен для плейсхолдера, если PasswordBox поддерживает -->
                    </DockPanel>

                    <!-- Показать/Скрыть -->
                    <Button x:Name="TogglePasswordVisibility"
                            Grid.Column="1"
                            Width="30"
                            Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Показать/Скрыть пароль">
                        <TextBlock Text="👁" FontSize="14" Foreground="#666"/>
                    </Button>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Кнопка Войти -->
        <Button Grid.Row="7"
                Height="40"
                Width="320"
                Content="Войти"
                Style="{StaticResource FormButtonStyle}"
                Background="Red"
                BorderBrush="Red"/>

        <!-- Кнопка выбрать пользователя -->
        <Button Grid.Row="8"
                Height="40"
                Width="320"
                Margin="0,10,0,0"
                Style="{StaticResource FormButtonStyle}"
                Background="#333"
                BorderBrush="#666"
                Cursor="Hand">
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Image Source="pack://application:,,,/Resources/Icons/User.png" Width="16" Height="16" Margin="0,0,6,0"/>
                <TextBlock Text="Выбрать пользователя" Foreground="White"/>
            </StackPanel>
        </Button>
    </Grid>
</UserControl>