<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Runord.Client.App.Converters">

    <!-- Цвет разделительной линии заголовков -->
    <SolidColorBrush x:Key="DataGridHorizontalGridLinesBrush" Color="#656565"/>
    
    <!-- Конвертер -->
    <conv:LastColumnBorderConverter x:Key="LastColumnBorderConverter"/>

    <!-- Стиль для заголовков колонок -->
    <Style x:Key="TableColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Height" Value="40"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="Background" Value="#262626"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="Rubik"/>
        <Setter Property="FontWeight" Value="Regular"/>
        <Setter Property="BorderBrush" Value="#303030"/>
        <Setter Property="BorderThickness">
            <Setter.Value>
                <MultiBinding Converter="{StaticResource LastColumnBorderConverter}">
                    <Binding Path="DisplayIndex" RelativeSource="{RelativeSource Self}"/>
                    <Binding Path="Columns.Count" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                </MultiBinding>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Стиль для строк -->
    <Style x:Key="TableRowStyle" TargetType="DataGridRow">
        <Setter Property="Height" Value="40"/>
        <Setter Property="Background" Value="#262626"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="Rubik"/>
        <Setter Property="FontWeight" Value="Normal"/>
    </Style>
</ResourceDictionary>