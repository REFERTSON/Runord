<!-- Resources/Styles/IconActionButton.xaml -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Цвета / кисти -->
    <SolidColorBrush x:Key="IconActionButtonBackgroundBrush" Color="#262626"/>
    <SolidColorBrush x:Key="IconActionButtonHoverBrush" Color="#333333"/>
    <SolidColorBrush x:Key="IconActionButtonPressedBrush" Color="#3F3F3F"/>
    <SolidColorBrush x:Key="IconActionButtonBorderBrush" Color="#303030"/>
    <SolidColorBrush x:Key="IconActionButtonForegroundBrush" Color="#FFFFFF"/>


    <!-- Карточка категории -->
    <Style x:Key="CategoryCardStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="{StaticResource IconActionButtonBorderBrush}"/>
        <Setter Property="Background" Value="{StaticResource IconActionButtonBackgroundBrush}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" BlurRadius="6" Opacity="0.2"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#333333"/>
                <Setter Property="BorderBrush" Value="#404040"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="Background" Value="#3F3F3F"/>
                <Setter Property="BorderBrush" Value="#505050"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="FilterCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource IconActionButtonForegroundBrush}"/>
        <Setter Property="Background" Value="{StaticResource IconActionButtonBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource IconActionButtonBorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="5,2"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4"
                        SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource IconActionButtonHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource IconActionButtonPressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource IconActionButtonHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Стиль для внешнего Border -->
    <Style x:Key="OuterBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="{StaticResource IconActionButtonBorderBrush}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Background" Value="{StaticResource IconActionButtonBackgroundBrush}"/>
    </Style>

    <!-- Стиль текста внутри кнопки -->
    <Style x:Key="IconActionButtonTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource IconActionButtonForegroundBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Главный стиль для Button с ControlTemplate (hover / pressed / disabled) -->
    <Style x:Key="IconActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource IconActionButtonBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              RecognizesAccessKey="True"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Наведение -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource IconActionButtonHoverBrush}"/>
                        </Trigger>

                        <!-- Нажатие -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource IconActionButtonPressedBrush}"/>
                        </Trigger>

                        <!-- Отключено -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>