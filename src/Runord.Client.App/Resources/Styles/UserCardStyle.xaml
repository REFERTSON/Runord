<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="UserCardStyle" TargetType="ContentControl">
        <Setter Property="Background" Value="#3F3F3F" />
        <Setter Property="BorderBrush" Value="#575757" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="Margin" Value="5" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border x:Name="CardBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}"
                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">

                        <DockPanel LastChildFill="True">
                            <!-- Аватар -->
                            <Image Source="{Binding AvatarPath}"
                               Width="48"
                               Height="48"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               Stretch="UniformToFill"
                               DockPanel.Dock="Left"
                               ClipToBounds="True"/>

                            <!-- Кнопка удаления -->
                            <Button Content="✕"
                                    DockPanel.Dock="Right"
                                    VerticalAlignment="Center"
                                    Width="24"
                                    Height="24"
                                    FontSize="14"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Foreground="#AAAAAA"
                                    Command="{Binding DataContext.RemoveUserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock x:Name="IconText"
                                                   Text="{TemplateBinding Content}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="{TemplateBinding FontSize}"
                                                   Foreground="{TemplateBinding Foreground}"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="IconText" Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Информация -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding UserName}"
                                           FontFamily="pack://application:,,,/Resources/Fonts/#Rubik Regular"
                                           FontSize="14"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           Margin="0,0,0,2"/>

                                <TextBlock Text="{Binding HubAddress}"
                                           FontFamily="pack://application:,,,/Resources/Fonts/#Rubik Regular"
                                           FontSize="12"
                                           Foreground="#CCCCCC"
                                           Margin="0,0,0,2"/>

                                <TextBlock Text="{Binding Role}"
                                           FontFamily="pack://application:,,,/Resources/Fonts/#Rubik Regular"
                                           FontSize="12"
                                           Foreground="#CCCCCC"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Подсветка при наведении -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CardBorder" Property="BorderBrush" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>