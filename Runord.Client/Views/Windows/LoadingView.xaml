<UserControl x:Class="Runord.Client.Views.Windows.LoadingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Runord.Client.Views.Windows"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d" 
             d:DesignHeight="350" d:DesignWidth="600"
             Height="350" Width="600">
    
    <Grid Background="#222222">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="33,33">
                <Label Content="RUNORD" FontWeight="Bold" FontFamily="Montserrat" Foreground="#E6E8EB" FontSize="40"/>
                <Label Content="v 0.0.1-beta" FontWeight="Regular" FontFamily="Montserrat" Foreground="#999999" FontSize="17" Margin="3,0,0,0"/>
            </StackPanel>

            <svgc:SvgViewbox Source="pack://application:,,,/Assets/Icons/Logo.svg" 
                             Width="39" Height="33.55" 
                             HorizontalAlignment="Right" 
                             VerticalAlignment="Top" 
                             Margin="0,47,56,0" />    
        </Grid>

        <Grid Grid.Row="2">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Bottom" 
                       HorizontalAlignment="Left" 
                       Margin="36,0,0,35"
                       Foreground="White" 
                       FontSize="16"
                       FontFamily="Montserrat"/>
        </Grid>

    </Grid>
</UserControl>
