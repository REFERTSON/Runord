<UserControl x:Class="Runord.Client.Views.Windows.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="420"
             Height="560"
             Background="#222222">

    <Grid>

        <!-- BACKGROUND -->
        <Border Background="#222222"/>

        <!-- CARD -->
        <Border Width="320"
                Height="390"
                CornerRadius="12"
                Background="#2B2B2B"
                BorderBrush="#3A3A3A"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid Margin="32">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- LOGO -->
                <TextBlock Text="RUNORD"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

                <!-- LOGIN -->
                <TextBlock Grid.Row="2"
                           Text="Username"
                           Foreground="#BEBEBE"
                           Margin="0,0,0,6"/>

                <Border Grid.Row="3"
                        Height="42"
                        CornerRadius="6"
                        Background="#1F1F1F"
                        BorderBrush="#3A3A3A"
                        BorderThickness="1">

                    <TextBox x:Name="UsernameBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             FontSize="14"
                             Margin="12,0"
                             VerticalContentAlignment="Center"/>
                </Border>

                <!-- PASSWORD -->
                <TextBlock Grid.Row="4"
                           Text="Password"
                           Foreground="#BEBEBE"
                           Margin="0,0,0,6"/>

                <Border Grid.Row="5"
                        Height="42"
                        CornerRadius="6"
                        Background="#1F1F1F"
                        BorderBrush="#3A3A3A"
                        BorderThickness="1">

                    <PasswordBox x:Name="PasswordBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White"
                                 FontSize="14"
                                 Margin="12,0"
                                 VerticalContentAlignment="Center"/>
                </Border>

                <!-- BUTTON -->
                <Button Grid.Row="6"
                        Height="42"
                        Content="Login"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Background="#5865F2"
                        BorderThickness="0"
                        Cursor="Hand">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">

                            <Border x:Name="Bd"
                                    CornerRadius="6"
                                    Background="{TemplateBinding Background}">

                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>

                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver"
                                         Value="True">

                                    <Setter TargetName="Bd"
                                            Property="Background"
                                            Value="#6B77FF"/>
                                </Trigger>

                                <Trigger Property="IsPressed"
                                         Value="True">

                                    <Setter TargetName="Bd"
                                            Property="Background"
                                            Value="#4752C4"/>
                                </Trigger>

                            </ControlTemplate.Triggers>

                        </ControlTemplate>
                    </Button.Template>

                </Button>

                <!-- FOOTER -->
                <TextBlock Grid.Row="8"
                           Text="Runord Client v1.0"
                           Foreground="#777777"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"/>

            </Grid>

        </Border>

    </Grid>
</UserControl>