<UserControl x:Class="Runord.Client.Views.Pages.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Runord.Client.Views.Pages"
             xmlns:uiElements="clr-namespace:Runord.Client.UIElements.Controls;assembly=Runord.Client.UIElements"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1120">

    <Grid Background="#191919">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="54,36,0,0">

            <TextBlock Text="Пользователи"
               FontSize="28.5"
               FontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/IBMPlexSans.ttf#IBM Plex Sans"
               FontWeight="Regular"
               Foreground="#FFFFFF"/>


            <StackPanel Orientation="Horizontal" 
                HorizontalAlignment="Left" 
                VerticalAlignment="Top" 
                Margin="0,21,0,0">

                <!-- Карточка 1 -->
                <uiElements:StatCard Header="ВСЕГО" 
                                 Value="{Binding TotalCount}" 
                                 Color="#A8A8A8" 
                                 Margin="0,0,24,0"/>

                <!-- Карточка 2 -->
                <uiElements:StatCard Header="В СЕТИ" 
                                 Value="{Binding OnlineCount}" 
                                 Color="#55FF6E" 
                                 Margin="0,0,24,0"/>

                <!-- Карточка 3 -->
                <uiElements:StatCard Header="НЕ В СЕТИ" 
                                 Value="{Binding OfflineCount}" 
                                 Color="#FF5555"/>

            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1"
        Margin="56,17,52,15"
        Height="55"
        BorderBrush="#3A3A3A" BorderThickness="1" Background="#212121">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>


                    <uiElements:PrimaryButton Grid.Column="1"
                             ButtonText="Фильтр"
                             Width="100" Height="35"
                             ButtonCornerRadius="3"
                             ButtonBackground="#FF2C2C2C"
                             ButtonForeground="White"
                             ButtonHoverBackground="#FF444444"
                             ButtonPressedBackground="#FF111111"
                             ButtonFontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex"
                             ButtonFontSize="12"
                             ButtonFontWeight="Medium"
                             ButtonIconWidth="14" ButtonIconHeight="14"
                             ButtonIconUri="pack://application:,,,/Runord.Client;component/Assets/Icons/Filter.svg"
                             Margin="12,0"/>

                    <uiElements:PrimaryButton Grid.Column="2"
                             ButtonText="Добавить пользователя"
                             Width="195" Height="35"
                             ButtonCornerRadius="3"
                             ButtonBackground="#FFFF4D4D"
                             ButtonForeground="White"
                             ButtonHoverBackground="#FFFF6666"
                             ButtonPressedBackground="#FFCC3333"
                             ButtonFontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex"
                             ButtonFontSize="12"
                             ButtonFontWeight="Medium"
                             ButtonIconUri="pack://application:,,,/Runord.Client;component/Assets/Icons/Add.svg"
                             ButtonIconWidth="10" ButtonIconHeight="10"
                             Margin="0,0,14,0"/>
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="62,10,18,20">
            <ItemsControl ItemsSource="{Binding Users}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <uiElements:UserCard 
                                UserName="{Binding UserName}" 
                                UserRole="{Binding UserRole}" 
                                Email="{Binding Email}"
                                LastActivity="{Binding LastActivity}"
                                StatusText="{Binding StatusText}"
                                IsOnline="{Binding IsOnline}"
                                Width="307"
                                Height="130"
                                Margin="0,0,24,24"
                                
                                EditCommand="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                EditCommandParameter="{Binding}"
                                DeleteCommand="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                DeleteCommandParameter="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
