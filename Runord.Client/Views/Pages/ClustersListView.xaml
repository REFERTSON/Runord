<UserControl x:Class="Runord.Client.Views.Pages.ClusterListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Runord.Client.Views.Pages"
             xmlns:uiElements="clr-namespace:Runord.Client.UIElements.Controls;assembly=Runord.Client.UIElements"
             xmlns:converters="clr-namespace:Runord.Client.UIElements.Converters;assembly=Runord.Client.UIElements"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1120"
             x:Name="pageRoot">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility"/>

        <Style TargetType="RadioButton" x:Key="ModernRadioButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="OuterBorder" 
                            Width="16" Height="16" CornerRadius="8" 
                            BorderBrush="#555555" BorderThickness="1" 
                            Background="#191919" VerticalAlignment="Center">
                                <Ellipse x:Name="CheckMark" Width="8" Height="8" 
                                 Fill="#FFFF4D4D" Visibility="Collapsed" Margin="3"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#FFFF4D4D"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#FF6666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#191919">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="56,36,0,0" Grid.Row="0">
            <TextBlock Text="Кластеры"
               FontSize="28.5"
               FontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/IBMPlexSans.ttf#IBM Plex Sans"
               FontWeight="Regular"
               Foreground="#FFFFFF"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,15,0,0">
                <uiElements:StatCard Header="ВСЕГО" Value="{Binding TotalCount, FallbackValue=0}" Color="#FFFFFF" Margin="0,0,24,0"/>
                <uiElements:StatCard Header="В СЕТИ" Value="{Binding OnlineCount, FallbackValue=0}" Color="#55FF6E" Margin="0,0,24,0"/>
                <uiElements:StatCard Header="ОТКЛЮЧЕННЫ" Value="{Binding OfflineCount, FallbackValue=0}" Color="#FF5555"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Margin="56,17,52,15" Height="55" BorderBrush="#3A3A3A" BorderThickness="1" Background="#212121">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <uiElements:PrimaryButton Grid.Column="1"
                                     ButtonText="Фильтр"
                                     Width="100" Height="35"
                                     ButtonCommand="{Binding OpenFilterDialogCommand}"
                                     ButtonCornerRadius="3"
                                     ButtonBackground="#FF2C2C2C"
                                     ButtonForeground="White"
                                     ButtonHoverBackground="#FF444444"
                                     ButtonPressedBackground="#FF111111"
                                     ButtonFontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex"
                                     ButtonFontSize="12"
                                     ButtonFontWeight="Medium"
                                     ButtonIconWidth="14" ButtonIconHeight="14"
                                     ButtonIconUri="pack://application:,,,/Runord.Client;component/Assets/Icons/Filter.svg"
                                     Margin="12,0"/>

                    <uiElements:PrimaryButton Grid.Column="2"
                                     ButtonText="Добавить кластер"
                                     Width="155" Height="35"
                                     ButtonCommand="{Binding OpenAddDialogCommand}"
                                     ButtonCornerRadius="3"
                                     ButtonBackground="#FFFF4D4D"
                                     ButtonForeground="White"
                                     ButtonHoverBackground="#FFFF6666"
                                     ButtonPressedBackground="#FFCC3333"
                                     ButtonFontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex"
                                     ButtonFontSize="12"
                                     ButtonFontWeight="Medium"
                                     ButtonIconUri="pack://application:,,,/Runord.Client;component/Assets/Icons/Add.svg"
                                     ButtonIconWidth="10" ButtonIconHeight="10"
                                     Margin="0,0,14,0"/>
                </Grid>
            </Grid>
        </Border>

        <uiElements:NotFoundBanner Grid.Row="2" MaxWidth="550" Margin="54,10,54,40"
                                   Header="{Binding BannerHeader, FallbackValue='Загрузка...'}"
                                   Message="{Binding BannerMessage, FallbackValue='Пожалуйста, подождите.'}"
                                   Visibility="{Binding IsListEmpty, Converter={StaticResource BoolToVisibility}}"/>

        <ScrollViewer Grid.Row="2" Margin="50,0,20,30" VerticalScrollBarVisibility="Auto" Visibility="{Binding IsListEmpty, Converter={StaticResource InverseBoolToVisibility}}">
            <ListBox ItemsSource="{Binding NodesList}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <uiElements:NodeCard Width="307" Height="130" Margin="12"
                                     IsOnline="{Binding IsOnline}"
                                     NodeName="{Binding Name}"
                                     NodeIp="{Binding Ip}"
                                     NodeStatusText="{Binding StatusText}"
                                     CpuUsage="{Binding Cpu}"
                                     RamUsage="{Binding Ram}"
                                     EditCommand="{Binding DataContext.EditNodeCommand, ElementName=pageRoot}"
                                     EditCommandParameter="{Binding}"
                                     DeleteCommand="{Binding DataContext.DeleteNodeCommand, ElementName=pageRoot}"
                                     DeleteCommandParameter="{Binding}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <Grid Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="10"
              Background="#80000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              Visibility="{Binding IsFilterDialogVisible, Converter={StaticResource BoolToVisibility}}">

            <Border Width="450" Height="300" Background="#212121" BorderBrush="#3A3A3A" BorderThickness="2" CornerRadius="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Фильтр кластеров" Foreground="#FFFFFF" FontSize="18" FontWeight="Medium" FontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/IBMPlexSans.ttf#IBM Plex Sans" Margin="0,0,0,20"/>

                    <StackPanel Grid.Row="1" VerticalAlignment="Top">
                        <TextBlock Text="Поиск (Имя или IP-адрес)" Foreground="#888888" FontSize="12" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding FilterSearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="#191919" Foreground="#FFFFFF" BorderBrush="#3A3A3A"
                                 Padding="8,6" FontSize="14" Margin="0,0,0,20" CaretBrush="White"/>

                        <TextBlock Text="Состояние" Foreground="#888888" FontSize="12" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Все" 
                                         Style="{StaticResource ModernRadioButton}" 
                                         IsChecked="{Binding IsFilterAll}" Margin="0,0,24,0"/>

                                                    <RadioButton Content="В сети" 
                                         Style="{StaticResource ModernRadioButton}" 
                                         IsChecked="{Binding IsFilterOnline}" Margin="0,0,24,0"/>

                                                    <RadioButton Content="Отключенные" 
                                         Style="{StaticResource ModernRadioButton}" 
                                         IsChecked="{Binding IsFilterOffline}"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <uiElements:PrimaryButton Grid.Column="0" ButtonText="Сбросить" Width="90" Height="35" Margin="0,0,12,0" ButtonCommand="{Binding ResetFilterCommand}" ButtonBackground="Transparent" ButtonForeground="#FFFF4D4D" BorderBrush="#FFFF4D4D" BorderThickness="1" ButtonHoverBackground="#1AFFFF4D" ButtonPressedBackground="#33FFFF4D" ButtonFontSize="12" ButtonCornerRadius="3"/>
                        <uiElements:PrimaryButton Grid.Column="1" ButtonText="Отмена" Width="90" Height="35" Margin="0,0,12,0" ButtonCommand="{Binding CloseFilterDialogCommand}" ButtonBackground="#FF2C2C2C" ButtonForeground="White" ButtonHoverBackground="#FF444444" ButtonPressedBackground="#FF111111" ButtonFontSize="12" ButtonCornerRadius="3"/>
                        <uiElements:PrimaryButton Grid.Column="2" ButtonText="Применить" Width="110" Height="35" ButtonCommand="{Binding ApplyFilterCommand}" ButtonBackground="#FFFF4D4D" ButtonForeground="White" ButtonHoverBackground="#FFFF6666" ButtonPressedBackground="#FFCC3333" ButtonFontSize="12" ButtonCornerRadius="3"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="10"
              Background="#80000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              Visibility="{Binding IsAddDialogVisible, Converter={StaticResource BoolToVisibility}}">
            <Border Width="420" Height="300" Background="#212121" BorderBrush="#3A3A3A" BorderThickness="2" CornerRadius="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding DialogTitle}" Foreground="#FFFFFF" FontSize="18" FontWeight="Medium" FontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/IBMPlexSans.ttf#IBM Plex Sans" Margin="0,0,0,20"/>

                    <StackPanel Grid.Row="1" VerticalAlignment="Top">
                        <TextBlock Text="Название кластера" Foreground="#888888" FontSize="12" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding NewNodeName, UpdateSourceTrigger=PropertyChanged}" Background="#191919" Foreground="#FFFFFF" BorderBrush="#3A3A3A" Padding="8,6" FontSize="14" Margin="0,0,0,16" CaretBrush="White"/>

                        <TextBlock Text="IP-адрес" Foreground="#888888" FontSize="12" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding NewNodeIp, UpdateSourceTrigger=PropertyChanged}" Background="#191919" Foreground="#FFFFFF" BorderBrush="#3A3A3A" Padding="8,6" FontSize="14" CaretBrush="White"/>
                    </StackPanel>

                    <Grid Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <uiElements:PrimaryButton Grid.Column="0" ButtonText="Отмена" Width="100" Height="35" Margin="0,0,12,0" ButtonCommand="{Binding CloseAddDialogCommand}" ButtonBackground="#FF2C2C2C" ButtonForeground="White" ButtonHoverBackground="#FF444444" ButtonPressedBackground="#FF111111" ButtonFontSize="12" ButtonCornerRadius="3"/>
                        <uiElements:PrimaryButton Grid.Column="1" ButtonText="Сохранить" Width="110" Height="35" ButtonCommand="{Binding ConfirmAddNodeCommand}" ButtonBackground="#FFFF4D4D" ButtonForeground="White" ButtonHoverBackground="#FFFF6666" ButtonPressedBackground="#FFCC3333" ButtonFontSize="12" ButtonCornerRadius="3"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="10"
              Background="#80000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              Visibility="{Binding IsDeleteDialogVisible, Converter={StaticResource BoolToVisibility}}">

            <Border Width="420" Height="220" Background="#212121" BorderBrush="#3A3A3A" BorderThickness="2" CornerRadius="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Удаление кластера" Foreground="#FFFFFF" FontSize="18" FontWeight="Medium" FontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/IBMPlexSans.ttf#IBM Plex Sans" Margin="0,0,0,15"/>

                    <TextBlock Grid.Row="1" Text="Вы действительно хотите удалить этот кластер? Данное действие невозможно отменить, и все текущие задачи на нём будут прерваны." 
                               Foreground="#CCCCCC" FontSize="14" TextWrapping="Wrap" LineHeight="20" VerticalAlignment="Top"/>

                    <Grid Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <uiElements:PrimaryButton Grid.Column="0" ButtonText="Отмена" Width="100" Height="35" Margin="0,0,12,0" 
                                                  ButtonCommand="{Binding CloseDeleteDialogCommand}" 
                                                  ButtonBackground="#FF2C2C2C" ButtonForeground="White" 
                                                  ButtonHoverBackground="#FF444444" ButtonPressedBackground="#FF111111" 
                                                  ButtonFontSize="12" ButtonCornerRadius="3"/>

                        <uiElements:PrimaryButton Grid.Column="1" ButtonText="Удалить" Width="110" Height="35" 
                                                  ButtonCommand="{Binding ConfirmDeleteNodeCommand}" 
                                                  ButtonBackground="#FFFF4D4D" ButtonForeground="White" 
                                                  ButtonHoverBackground="#FFFF6666" ButtonPressedBackground="#FFCC3333" 
                                                  ButtonFontSize="12" ButtonCornerRadius="3"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>