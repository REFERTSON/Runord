<UserControl x:Class="Runord.Client.Views.Pages.TaskDispatherView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Runord.Client.Views.Pages"
             xmlns:uiElements="clr-namespace:Runord.Client.UIElements.Controls;assembly=Runord.Client.UIElements"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1120">

    <UserControl.Resources>
        <Style x:Key="DarkColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="10,0,10,12"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#2D2D2D"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="DarkCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" Margin="10,0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#222222"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#202020"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#252525"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#191919">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="54,36,0,0">
            <TextBlock Text="Диспетчер"
                       FontSize="28.5"
                       FontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/IBMPlexSans.ttf#IBM Plex Sans"
                       FontWeight="Regular"
                       Foreground="#FFFFFF"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,21,0,0">
                <uiElements:StatCard Header="КОЛ-ВО ЗАДАЧ" Value="2566" Color="#55FF6E" Margin="0,0,20,0"/>
                <uiElements:StatCard Header="ОЖИДАНИЕ" Value="2566" Color="#FFB237" Margin="0,0,20,0"/>
                <uiElements:StatCard Header="ВЫПОЛНЯЕТСЯ" Value="2566" Color="#55A4FF" Margin="0,0,20,0"/>
                <uiElements:StatCard Header="ОШИБКА" Value="200" Color="#FF5555" Margin="0,0,20,0"/>
                <uiElements:StatCard Header="ОТМЕНЕНО" Value="155" Color="#A8A8A8"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Margin="56,17,52,15" Height="55" BorderBrush="#3A3A3A" BorderThickness="1" Background="#212121">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <uiElements:PrimaryButton Grid.Column="1" ButtonText="Фильтр" Width="100" Height="35" ButtonCornerRadius="3" ButtonBackground="#FF2C2C2C" ButtonForeground="White" ButtonHoverBackground="#FF444444" ButtonPressedBackground="#FF111111" ButtonFontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex" ButtonFontSize="12" ButtonFontWeight="Medium" ButtonIconWidth="14" ButtonIconHeight="14" ButtonIconUri="pack://application:,,,/Runord.Client;component/Assets/Icons/Filter.svg" Margin="12,0"/>
                    <uiElements:PrimaryButton Grid.Column="2" ButtonText="Создать задачу" Width="143" Height="35" ButtonCornerRadius="3" ButtonBackground="#FFFF4D4D" ButtonForeground="White" ButtonHoverBackground="#FFFF6666" ButtonPressedBackground="#FFCC3333" ButtonFontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex" ButtonFontSize="12" ButtonFontWeight="Medium" ButtonIconUri="pack://application:,,,/Runord.Client;component/Assets/Icons/Add.svg" ButtonIconWidth="10" ButtonIconHeight="10" Margin="0,0,14,0"/>
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Margin="54,10,30,20">
            <ItemsControl ItemsSource="{Binding Tasks}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" VerticalAlignment="Top"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#212121" CornerRadius="4" Margin="0,0,16,16">
                            <Grid>
                                <Border x:Name="StatusStripe" 
                                        Width="3" Height="36" 
                                        Background="#FFB300" 
                                        CornerRadius="0,2,2,0" 
                                        HorizontalAlignment="Left" 
                                        VerticalAlignment="Top" 
                                        Margin="0,14,0,0"/>

                                <Grid Margin="24,12,14,12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Uuid}" Foreground="#555555" FontSize="10" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>

                                        <Border x:Name="PriorityBadge" Grid.Column="1" Background="#33FFFFFF" CornerRadius="3" Padding="6,2" Margin="0,0,10,0">
                                            <TextBlock x:Name="PriorityText" Text="{Binding Priority}" Foreground="#FFFFFF" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>

                                        <Button Grid.Column="2" 
                                                Command="{Binding DataContext.ViewTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                CommandParameter="{Binding}" 
                                                Background="Transparent" BorderThickness="0" Cursor="Hand" Width="20" Height="20" Margin="0,0,8,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Path Data="M12,4.5C7,4.5 2.73,7.61 1,12c1.73,4.39 6,7.5 11,7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12,17c-2.76,0-5-2.24-5-5s2.24-5,5-5 5,2.24 5,5-2.24,5-5,5zM12,9c-1.66,0-3,1.34-3,3s1.34,3,3,3 3-1.34,3-3-1.34-3-3-3z"
                                                          Fill="#888888" Stretch="Uniform" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.7"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <Button Grid.Column="3" 
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                CommandParameter="{Binding}" 
                                                Background="Transparent" BorderThickness="0" Cursor="Hand" Width="18" Height="18">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="✕" Foreground="#666666" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Name}" Foreground="#FFFFFF" FontSize="16" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Type}" Foreground="#888888" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <Grid Grid.Row="2" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="StatusText" Text="{Binding Status}" Foreground="#FFB300" FontSize="12" FontWeight="Bold"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="📁" Foreground="#888888" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Files}" Foreground="#A8A8A8" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="3" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar x:Name="TaskProgress" Value="{Binding Progress}" Maximum="100" Height="4" BorderThickness="0" Background="#333333" Foreground="#FFB300" Margin="0,0,14,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat={}{0}%}" Foreground="#FFFFFF" FontSize="13" FontWeight="Medium"/>
                                    </Grid>

                                    <Grid Grid.Row="4">
                                        <TextBlock Text="{Binding Owner}" Foreground="#A8A8A8" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding Priority}" Value="Высокий">
                                <Setter TargetName="PriorityBadge" Property="Background" Value="#33FF5555"/>
                                <Setter TargetName="PriorityText" Property="Foreground" Value="#FF5555"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding Priority}" Value="Средний">
                                <Setter TargetName="PriorityBadge" Property="Background" Value="#33FFB300"/>
                                <Setter TargetName="PriorityText" Property="Foreground" Value="#FFB300"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding Priority}" Value="Низкий">
                                <Setter TargetName="PriorityBadge" Property="Background" Value="#3355AAFF"/>
                                <Setter TargetName="PriorityText" Property="Foreground" Value="#55AAFF"/>
                            </DataTrigger>
                            
                            <DataTrigger Binding="{Binding Status}" Value="Выполняется">
                                <Setter TargetName="StatusStripe" Property="Background" Value="#55AAFF"/>
                                <Setter TargetName="StatusText" Property="Foreground" Value="#55AAFF"/>
                                <Setter TargetName="TaskProgress" Property="Foreground" Value="#55AAFF"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Выполнено">
                                <Setter TargetName="StatusStripe" Property="Background" Value="#55FF6E"/>
                                <Setter TargetName="StatusText" Property="Foreground" Value="#55FF6E"/>
                                <Setter TargetName="TaskProgress" Property="Foreground" Value="#55FF6E"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Ошибка">
                                <Setter TargetName="StatusStripe" Property="Background" Value="#FF5555"/>
                                <Setter TargetName="StatusText" Property="Foreground" Value="#FF5555"/>
                                <Setter TargetName="TaskProgress" Property="Foreground" Value="#FF5555"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Отменено">
                                <Setter TargetName="StatusStripe" Property="Background" Value="#A8A8A8"/>
                                <Setter TargetName="StatusText" Property="Foreground" Value="#A8A8A8"/>
                                <Setter TargetName="TaskProgress" Property="Foreground" Value="#A8A8A8"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>