<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Стиль для самого ползунка (Thumb) -->
    <Style x:Key="ScrollThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="#4A4A4A" Margin="2,0"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Основной стиль ScrollBar -->
    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Background" Value="#1B1C1E"/>
        <Setter Property="Width" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Кнопка "Вверх" -->
                        <RepeatButton Grid.Row="0" Command="ScrollBar.LineUpCommand" Height="15" Background="Transparent" BorderThickness="0">
                            <Path Data="M 0 4 L 4 0 L 8 4 Z" Fill="#6C727F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </RepeatButton>

                        <!-- Область перемещения -->
                        <Track Grid.Row="1" Name="PART_Track" IsDirectionReversed="true">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollThumbStyle}"/>
                            </Track.Thumb>
                        </Track>

                        <!-- Кнопка "Вниз" -->
                        <RepeatButton Grid.Row="2" Command="ScrollBar.LineDownCommand" Height="15" Background="Transparent" BorderThickness="0">
                            <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="#6C727F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </RepeatButton>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>