<UserControl x:Class="Runord.Client.UIElements.Controls.SidebarMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/" 
             xmlns:controls="clr-namespace:Runord.Client.UIElements.Controls"
             mc:Ignorable="d" d:Height="768" d:DesignWidth="270"
             MinWidth="72" Width="270">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Runord.Client.UIElements;component/Assets/Styles/ScrollBarStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#1B1C1E" RadioButton.Checked="MenuButton_Checked">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel x:Name="Logo" Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <svgc:SvgViewbox Grid.Column="0"
                                 Source="pack://application:,,,/Runord.Client.UIElements;component/Assets/Icons/Logo.svg" 
                                 Width="32" Height="27.53" 
                                 HorizontalAlignment="Left" 
                                 VerticalAlignment="Top" 
                                 Margin="30,33,0,29"/>

                <Label Grid.Column="1"
                       Content="RUNORD"
                       FontSize="16"
                       FontFamily="Montserrat"
                       Foreground="#E6E8EB"
                       FontWeight="Bold"
                       HorizontalAlignment="Left"
                       Margin="11,33,0,33"/>
            </Grid>

            <Border Height="1" Background="#303540" Margin="20,0"/>
        </StackPanel>

        <Grid x:Name="Menu" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <StackPanel Margin="0,11,0,0">
                        <controls:SidebarMenuButton 
                            IconSource="pack://application:,,,/Runord.Client.UIElements;component/Assets/Icons/Dashboard.svg"
                            TextButton="Главная" 
                            StripeColor="#F25555"
                            Tag="{x:Static controls:NavigationType.Dashboard}"
                            IsActive="True"
                            Margin="27,13,27,0"/>

                        <controls:SidebarMenuButton
                            IconSource="pack://application:,,,/Runord.Client.UIElements;component/Assets/Icons/Builder.svg"
                            TextButton="Конструктор" 
                            Tag="{x:Static controls:NavigationType.TaskBuilder}"
                            Margin="27,13,27,0"/>

                        <controls:SidebarMenuButton
                            IconSource="pack://application:,,,/Runord.Client.UIElements;component/Assets/Icons/Projects.svg"
                            TextButton="Проекты" 
                            Tag="{x:Static controls:NavigationType.ProjectsList}"
                            Margin="27,13,27,24"/>
                    </StackPanel>

                    <Border Height="1" Background="#303540" Margin="20,0"/>

                    <StackPanel Margin="0,11,0,0">
                        <controls:SidebarMenuButton 
                            IconSource="pack://application:,,,/Runord.Client.UIElements;component/Assets/Icons/Monitor.svg"
                            TextButton="Диспетчер" 
                            Tag="{x:Static controls:NavigationType.TaskDispatcher}"
                            Margin="27,13,27,0"/>

                        <controls:SidebarMenuButton
                            IconSource="pack://application:,,,/Runord.Client.UIElements;component/Assets/Icons/Clusters.svg"
                            TextButton="Кластеры" 
                            Tag="{x:Static controls:NavigationType.ClusterList}"
                            Margin="27,13,27,0"/>

                        <controls:SidebarMenuButton
                            IconSource="pack://application:,,,/Runord.Client.UIElements;component/Assets/Icons/Users.svg"
                            TextButton="Пользователи" 
                            Tag="{x:Static controls:NavigationType.UserManagement}"
                            Margin="27,13,27,24"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1" Margin="0,11,0,0">
                <controls:SidebarMenuButton x:Name="NotificationButton"
                    IconSource="pack://application:,,,/Runord.Client.UIElements;component/Assets/Icons/Notifications.svg"
                    TextButton="Уведомления"
                    Tag="{x:Static controls:NavigationType.NotificationCenter}"
                    Margin="27,13,27,0"/>

                <controls:SidebarMenuButton 
                    IconSource="pack://application:,,,/Runord.Client.UIElements;component/Assets/Icons/Settings.svg"
                    TextButton="Настройки" 
                    Tag="{x:Static controls:NavigationType.Settings}"
                    Margin="27,13,27,9"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="MenuUserProfile" Grid.Row="2">
            <Border Background="#212121" 
                    CornerRadius="3" 
                    Margin="17,15"
                    Padding="12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Width="35" Height="35" VerticalAlignment="Center">
                        <Border x:Name="DefaultAvatar" Background="#303540" CornerRadius="100">
                            <TextBlock Text="RR" Foreground="#E6E8EB" FontSize="10.5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <Border CornerRadius="100" ClipToBounds="True">
                            <Image Source="{Binding AvatarSource, RelativeSource={RelativeSource AncestorType=UserControl}}" Stretch="UniformToFill">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <Trigger Property="Source" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </Trigger>
                                        </Style.Triggers>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="REFERTSON RUMITI..." 
                                   Foreground="#FFFFFF" 
                                   FontSize="12" 
                                   FontFamily="pack://application:,,,/Runord.Client.UIElements;component/Assets/Fonts/Inter.ttf#Inter"
                                   FontWeight="Medium"/>

                        <TextBlock Text="Администратор" 
                                   FontFamily="pack://application:,,,/Runord.Client.UIElements;component/Assets/Fonts/Inter.ttf#Inter"
                                   FontWeight="Medium"
                                   Foreground="#6C727F" 
                                   FontSize="9" 
                                   Margin="0,1,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="2" 
                            Width="32" 
                            Height="32"
                            VerticalAlignment="Center" 
                            Cursor="Hand" 
                            Click="ProfileMenuButton_Click" 
                            Margin="5,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="3">
                                                <svgc:SvgViewbox Source="pack://application:,,,/Runord.Client.UIElements;component/Assets/Icons/More.svg" 
                                                                 Width="14" 
                                                                 Height="14" 
                                                                 HorizontalAlignment="Center" 
                                                                 VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Background" Value="#303540"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>

                        <Button.ContextMenu>
                            <ContextMenu Background="#1B1C1E" BorderBrush="#303540" BorderThickness="1">
                                <ContextMenu.Style>
                                    <Style TargetType="ContextMenu">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContextMenu">
                                                    <Border Background="#1B1C1E" 
                                                            BorderBrush="#303540" 
                                                            BorderThickness="1" 
                                                            CornerRadius="6" 
                                                            Padding="4">
                                                        <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ContextMenu.Style>

                                <ContextMenu.Resources>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Foreground" Value="#E6E8EB"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="FontFamily" Value="pack://application:,,,/Runord.Client.UIElements;component/Assets/Fonts/Inter.ttf#Inter"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="MenuItem">
                                                    <Border x:Name="ItemBorder" Background="Transparent" Padding="16,10" CornerRadius="4" Margin="0,1">
                                                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#303540"/>
                                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ContextMenu.Resources>

                                <MenuItem Header="Личный кабинет" Click="OpenProfile_Click"/>
                                <MenuItem Header="Сменить аккаунт"/>
                                <MenuItem Header="Выйти"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </Border>

            <Border x:Name="ProfileIndicatorStripe"
                    Width="3"
                    Height="16"
                    Background="#F25555"
                    CornerRadius="1.5,0,0,1.5"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,17,0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleY="0"/>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsProfileActive, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                             To="1" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                             To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                             To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
        </Grid>
    </Grid>
</UserControl>