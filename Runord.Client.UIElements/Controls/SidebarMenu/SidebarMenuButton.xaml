<UserControl x:Class="Runord.Client.UIElements.Controls.SidebarMenuButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d" 
             MinWidth="186" MinHeight="40">

    <RadioButton GroupName="SidebarNavigationGroup"
                 IsChecked="{Binding IsActive, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                 Focusable="False"
                 Cursor="Hand">
        <RadioButton.Template>
            <ControlTemplate TargetType="RadioButton">
                <Border x:Name="BtnBorder" 
                        Background="Transparent" 
                        CornerRadius="3" 
                        SnapsToDevicePixels="True">
                    <Grid>
                        <!-- Добавлена колонка для счетчика -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <svgc:SvgViewbox x:Name="IconViewer"
                                         Grid.Column="0"
                                         Source="{Binding IconSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                         Width="20"
                                         Height="20"
                                         Margin="12,5,7,5"
                                         Opacity="0.5"/>

                        <TextBlock x:Name="BtnText"
                                   Grid.Column="1"
                                   Text="{Binding TextButton, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='ЗАГОЛОВОК'}"
                                   FontSize="12"
                                   FontFamily="pack://application:,,,/Runord.Client.UIElements;component/Assets/Fonts/Inter.ttf#Inter"
                                   FontWeight="Medium"
                                   Foreground="{Binding TextButtonColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   VerticalAlignment="Center"
                                   Margin="10,6,10,5"/>

                        <!-- СТИЛЬНЫЙ СЧЕТЧИК (Badge) -->
                        <Border x:Name="BadgeBorder"
                                Grid.Column="2"
                                Background="{Binding StripeColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CornerRadius="2"
                                MinWidth="18"
                                Height="18"
                                Padding="5,0,6,1"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <!-- Скрываем, если значение null или пустая строка -->
                                        <DataTrigger Binding="{Binding NotificationCount, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NotificationCount, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding NotificationCount, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       Foreground="#FFFFFF" 
                                       FontSize="10" 
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Border x:Name="IndicatorStripe"
                                Grid.Column="3"
                                Width="3"
                                Height="16"
                                Background="{Binding StripeColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CornerRadius="1.5,0,0,1.5"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                RenderTransformOrigin="0.5,0.5"
                                Opacity="0">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleY="0"/>
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                </Border>

                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="BtnBorder" Property="Background" Value="#2A2D35"/>
                        <Setter TargetName="BtnText" Property="Foreground" Value="#E6E8EB"/>
                        <Setter TargetName="IconViewer" Property="Opacity" Value="0.85"/>
                    </Trigger>

                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="BtnBorder" Property="Background" Value="#141517"/>
                    </Trigger>

                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="BtnBorder" Property="Background" Value="#22252A"/>
                        <Setter TargetName="BtnText" Property="Foreground" Value="#FFFFFF"/>
                        <Setter TargetName="IconViewer" Property="Opacity" Value="1.0"/>

                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="IndicatorStripe" 
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                     To="1" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="IndicatorStripe" 
                                                     Storyboard.TargetProperty="Opacity" 
                                                     To="1" Duration="0:0:0.15"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>

                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="IndicatorStripe" 
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                     To="0" Duration="0:0:0.2">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseIn"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="IndicatorStripe" 
                                                     Storyboard.TargetProperty="Opacity" 
                                                     To="0" Duration="0:0:0.15"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </RadioButton.Template>
    </RadioButton>
</UserControl>
