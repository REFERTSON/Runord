<UserControl x:Class="Runord.Client.UIElements.Controls.NodeCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Runord.Client.UIElements.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="130" d:DesignWidth="307"
             x:Name="nodeCardRoot">

    <!-- Добавлено скругление CornerRadius="5", как у проектов -->
    <Border Background="#212121" CornerRadius="3">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Левый цветной маркер статуса (Онлайн / Оффлайн) -->
            <Border Grid.Column="0" 
                    CornerRadius="0,3,3,0" 
                    Width="5"
                    Height="30"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="0,16">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#FF5555"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOnline, ElementName=nodeCardRoot}" Value="True">
                                <Setter Property="Background" Value="#55FF6E"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <!-- Центральная часть: Сетка вместо StackPanel для жесткого позиционирования верх-низ -->
            <Grid Grid.Column="1" Margin="14,16,10,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Шапка: Имя ноды -->
                    <RowDefinition Height="Auto"/>
                    <!-- Подзаголовок: IP и Статус -->
                    <RowDefinition Height="*"/>
                    <!-- Пружина-распорка -->
                    <RowDefinition Height="Auto"/>
                    <!-- Низ: Метрики железа (CPU, RAM) -->
                </Grid.RowDefinitions>

                <!-- Название ноды (Размер приведен к общему стандарту 14px + Medium) -->
                <TextBlock Grid.Row="0" 
                           Text="{Binding NodeName, ElementName=nodeCardRoot}"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="Medium"
                           FontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,4"/>

                <!-- IP-адрес и текстовый статус -->
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <TextBlock Text="{Binding NodeIp, ElementName=nodeCardRoot}"
                               Foreground="#888888"
                               FontSize="11"
                               FontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex"/>
                    <TextBlock Text=" - " Foreground="#888888" FontSize="11"
                               FontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex"/>
                    <TextBlock Text="{Binding NodeStatusText, ElementName=nodeCardRoot}" 
                               FontSize="11"
                               FontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FF5555"/>
                                
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnline, ElementName=nodeCardRoot}" Value="True">
                                        <Setter Property="Foreground" Value="#55FF6E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Нижний блок: Системные ресурсы (CPU и RAM аккуратно разнесены или стоят снизу) -->
                <StackPanel Grid.Row="3" Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <TextBlock Text="CPU: " Foreground="#CCCCCC" FontSize="12"
                                   FontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex"/>
                        <TextBlock Text="{Binding CpuUsage, ElementName=nodeCardRoot}" 
                                   Foreground="White" FontSize="12" FontWeight="Medium"
                                   FontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="RAM: " Foreground="#CCCCCC" FontSize="12"
                                   FontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex"/>
                        <TextBlock Text="{Binding RamUsage, ElementName=nodeCardRoot}" 
                                   Foreground="White" FontSize="12" FontWeight="Medium"
                                   FontFamily="pack://application:,,,/Runord.Client;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Правая часть: Кнопки управления (заменил Margin под новые отступы 16px сверху) -->
            <StackPanel Grid.Column="2" 
                        Orientation="Horizontal" 
                        VerticalAlignment="Top" 
                        Margin="0,16,16,0">

                <local:PrimaryButton Width="26" Height="26"
                                     ButtonCornerRadius="3"
                                     Margin="0,0,10,0"
                                     ButtonBackground="#2C2C2C" ButtonHoverBackground="#404040" ButtonPressedBackground="#1A1A1A"
                                     ButtonIconWidth="10" ButtonIconHeight="10" ButtonForeground="#AAAAAA"
                                     ButtonIconUri="pack://application:,,,/Runord.Client.UIElements;component/Assets/Icons/Edit.svg"
                                     ButtonCommand="{Binding EditCommand, ElementName=nodeCardRoot}"
                                     ButtonCommandParameter="{Binding EditCommandParameter, ElementName=nodeCardRoot}"/>

                <local:PrimaryButton Width="26" Height="26"
                                     ButtonCornerRadius="3"
                                     ButtonBackground="#2C2C2C" ButtonHoverBackground="#404040" ButtonPressedBackground="#1A1A1A"
                                     ButtonIconWidth="10" ButtonIconHeight="10" ButtonForeground="#AAAAAA"
                                     ButtonIconUri="pack://application:,,,/Runord.Client.UIElements;component/Assets/Icons/Trash.svg"
                                     ButtonCommand="{Binding DeleteCommand, ElementName=nodeCardRoot}"
                                     ButtonCommandParameter="{Binding DeleteCommandParameter, ElementName=nodeCardRoot}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>