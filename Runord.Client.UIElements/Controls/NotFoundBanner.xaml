<UserControl x:Class="Runord.Client.UIElements.Controls.NotFoundBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Runord.Client.UIElements.Controls"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Background="Transparent">

        <Grid HorizontalAlignment="Center" 
              VerticalAlignment="Center"
              MaxWidth="650"
              Margin="30">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <svgc:SvgViewbox Grid.Column="0"
                             Source="pack://application:,,,/Runord.Client.UIElements;component/Assets/Icons/SadSmile.svg" 
                             Width="80" Height="80" 
                             HorizontalAlignment="Center" 
                             VerticalAlignment="Center"/>

            <!-- Текстовый блок справа от иконки -->
            <Grid Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок: добавляем x:Name, чтобы связать с ним нижний текст -->
                <TextBlock x:Name="HeaderTextBlock"
                           Grid.Row="0"
                           Text="{Binding Header, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='ЗАГОЛОВОК'}" 
                           FontFamily="/Runord.Client.UIElements;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex Medium"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF" 
                           FontSize="24"
                           HorizontalAlignment="Left"
                           TextWrapping="WrapWithOverflow"/>

                <!-- Сообщение: привязываем MaxWidth к текущей ширине заголовка -->
                <TextBlock Grid.Row="1"
                           Text="{Binding Message, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='СООБЩЕНИЕ'}" 
                           FontFamily="/Runord.Client.UIElements;component/Assets/Fonts/RobotoFlex.ttf#Roboto Flex Medium"
                           FontWeight="Regular"
                           Foreground="#8E8E93" 
                           FontSize="15"
                           Margin="0,6,0,0"
                           LineHeight="20"
                           HorizontalAlignment="Left"
                           MaxWidth="{Binding ActualWidth, ElementName=HeaderTextBlock}"
                           TextWrapping="Wrap"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
